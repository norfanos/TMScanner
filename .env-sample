# ─── TMScanner Configuration ──────────────────────────────────────────────────
# Copy this file to `.env` and fill in your real values.
# NEVER commit `.env` to git — only `.env-sample` is safe to share.

# ─── Event metadata (shown on the dashboard header) ───────────────────────────
EVENT_NAME=EDC Las Vegas 2026
EVENT_DATE=2026-05-15
EVENT_VENUE=Las Vegas Motor Speedway
# Optional — any public image URL (logo/poster).  Leave blank to hide.
EVENT_IMAGE=https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQCcuVf52XiK8uK7fZbt-RXRJ8Fz7IFiN2jYA&s

# ─── Target page ──────────────────────────────────────────────────────────────
# Full URL of the Ticketmaster Exchange event page to monitor.
SCAN_URL=https://www.ticketexchangebyticketmaster.com/seg134/some-event/tickets/1234567

# ─── Scan cadence ─────────────────────────────────────────────────────────────
# Seconds between scans.  Recommended: 60.
# (Per-tier alert thresholds are configured in the dashboard — see the
#  "Change" button on the Alert Threshold card.)
SCAN_INTERVAL=60

# ─── Telegram alerts ──────────────────────────────────────────────────────────
# Create a bot with @BotFather in Telegram.  See README for details.
TELEGRAM_TOKEN=0000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA
TELEGRAM_CHAT_ID=000000000

# ─── Database connections (usually no change needed) ──────────────────────────
MONGO_URL=mongodb://localhost:27017
REDIS_URL=redis://localhost:6379

# ─── Dashboard ────────────────────────────────────────────────────────────────
# Port the web dashboard listens on.
DASHBOARD_PORT=8181
